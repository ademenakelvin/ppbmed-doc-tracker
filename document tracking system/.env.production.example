DJANGO_SECRET_KEY=replace-with-a-new-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com
DJANGO_DB_ENGINE=postgres
POSTGRES_DB=ppbmed_db
POSTGRES_USER=ppbmed_user
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60
POSTGRES_SSLMODE=prefer
# MySQL alternative
# DJANGO_DB_ENGINE=mysql
# MYSQL_DATABASE=ppbmed_db
# MYSQL_USER=ppbmed_user
# MYSQL_PASSWORD=replace-with-a-strong-mysql-password
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_CONN_MAX_AGE=60
# MYSQL_CHARSET=utf8mb4
DJANGO_CACHE_BACKEND=redis
REDIS_URL=redis://127.0.0.1:6379/1
SESSION_IDLE_TIMEOUT=1800
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW=900
TWO_FACTOR_CODE_TTL=300
TWO_FACTOR_MAX_ATTEMPTS=5
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-smtp-user
EMAIL_HOST_PASSWORD=your-smtp-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@your-domain.com
SMS_BACKEND=console
SMS_FROM=PPBMED
